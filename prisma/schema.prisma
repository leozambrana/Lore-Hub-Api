// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id
  email     String    @unique
  username  String    @unique
  avatarUrl String?
  theories  Theory[]
  comments  Comment[]
  votes     Vote[]
  role      UserRole  @default(USER)
  createdAt DateTime  @default(now())
}

model Game {
  id        String     @id @default(uuid())
  title     String
  slug      String     @unique
  imageUrl  String?
  theories  Theory[]
  wikiItems WikiItem[]
  status    GameStatus @default(PENDING)
  createdAt DateTime   @default(now())
}

model Theory {
  id             String                @id @default(uuid())
  title          String
  content        String
  wikiUrl        String?
  wikiMetadata   Json?
  upvotes        Int                   @default(0)
  gameId         String
  game           Game                  @relation(fields: [gameId], references: [id])
  userId         String
  user           User                  @relation(fields: [userId], references: [id])
  comments       Comment[]
  votes          Vote[]
  wikiReferences TheoryWikiReference[]
  createdAt      DateTime              @default(now())
}

model Comment {
  id        String    @id @default(uuid())
  content   String
  theoryId  String
  theory    Theory    @relation(fields: [theoryId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())
}

model Vote {
  id       String   @id @default(uuid())
  type     VoteType
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  theoryId String
  theory   Theory   @relation(fields: [theoryId], references: [id], onDelete: Cascade)

  @@unique([userId, theoryId])
}

model WikiItem {
  id          String                @id @default(uuid())
  name        String
  description String
  category    WikiCategory
  imageUrl    String?
  gameId      String
  game        Game                  @relation(fields: [gameId], references: [id])
  theories    TheoryWikiReference[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model TheoryWikiReference {
  theoryId   String
  theory     Theory   @relation(fields: [theoryId], references: [id], onDelete: Cascade)
  wikiItemId String
  wikiItem   WikiItem @relation(fields: [wikiItemId], references: [id], onDelete: Cascade)

  @@id([theoryId, wikiItemId])
}

enum WikiCategory {
  CHARACTER
  ITEM
  LOCATION
  EVENT
  OTHER
}

enum VoteType {
  UP
  DOWN
}

enum GameStatus {
  PENDING
  APPROVED
}

enum UserRole {
  USER
  ADMIN
}
